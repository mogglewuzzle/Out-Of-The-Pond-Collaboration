    playerResponseText: 'I''m not interested in some stupid apple scavenger hunt.
      I''m a grown frogman not a child.  '
    nextNode: {fileID: 1710426774}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
    runDialogueEvent: 0
