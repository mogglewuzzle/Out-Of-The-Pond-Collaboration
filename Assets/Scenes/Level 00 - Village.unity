    objectsToDeactivate: []
  - choiceText: History of Apple Hunt
    playerResponseText: Do you know anything about the history of the apple hunt?
    nextNode: {fileID: 404847057}
    active: 1
    deactivateAfterChosen: 1
    goodbyeChoice: 0
    finalChoice: 0
    objectsToActivate: []
    objectsToDeactivate: []
  - choiceText: Goodbye
