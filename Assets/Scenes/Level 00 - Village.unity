  m_EditorClassIdentifier: Assembly-CSharp::Dialogue_Node
  speakerName: 
  dialogueText: 'Froggle let''s talk after the apple hunt! '
  choices:
  - choiceText: I'll miss you
    playerResponseText: 'Okay but I''ll miss you every moment while we''re apart! '
    nextNode: {fileID: 1863162167}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
    runDialogueEvent: 0
    dialogueEventId: 
  - choiceText: 'Okay '
    playerResponseText: 'You''re right! No time to lose!  '
    nextNode: {fileID: 0}
    active: 1
    deactivateAfterChosen: 1
    goodbyeChoice: 1
    finalChoice: 1
    runDialogueEvent: 0
    dialogueEventId: 
  - choiceText: Go Away
    playerResponseText: 'Get out of my way I don''t have time to talk.  '
    nextNode: {fileID: 0}
    active: 1
    deactivateAfterChosen: 1
    goodbyeChoice: 0
    finalChoice: 0
