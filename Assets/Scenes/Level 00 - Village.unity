--- !u!114 &2136447668
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2136447666}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4eed38e452d87c7428f4c86506a4d752, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue_Node
  speakerName: 
  dialogueText: 'Good morning Froggle. I didn''t expect to see you so early in the
    morning. Is something the matter? '
  choices:
  - choiceText: I'm fine.
    playerResponseText: 'Actually, I''m doing really well good sir Elder frog. '
    nextNode: {fileID: 1274569366}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
    objectsToActivate: []
    objectsToDeactivate: []
  - choiceText: I want a family.
    playerResponseText: 'I think I''m ready to start a family, but I''m scared. What
      was it like when you had your first child? '
    nextNode: {fileID: 302929777}
    active: 1
    deactivateAfterChosen: 1
    goodbyeChoice: 0
    finalChoice: 0
    objectsToActivate: []
    objectsToDeactivate: []
  - choiceText: 'I want to leave the village. '
    playerResponseText: I hate it here sir Elder frog. This village is holding back
      and it's time I explored the world!
    nextNode: {fileID: 1274569366}
    active: 1
    deactivateAfterChosen: 1
    goodbyeChoice: 0
    finalChoice: 0
    objectsToActivate: []
    objectsToDeactivate: []
