    same here. But I can''t let you out. '
  choices:
  - choiceText: Why
    playerResponseText: 'Why not? I thought we were free to leave whenever we wanted. '
    nextNode: {fileID: 228931047}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
    runDialogueEvent: 0
    dialogueEventId: 
  - choiceText: Enough Talk
    playerResponseText: 'Enough chit chat. Let me out immediately! '
    nextNode: {fileID: 228931047}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
    runDialogueEvent: 0
    dialogueEventId: 
