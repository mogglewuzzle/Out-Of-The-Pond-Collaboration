  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue_Node
  speakerName: 
  dialogueText: 'Heyya Froggle good sir! Lovely day for fishing isnt it? '
  choices:
  - choiceText: 'Sure is! '
    playerResponseText: 'It''s beautiful weather. I hope you catch something!  '
    nextNode: {fileID: 0}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 1
    finalChoice: 1
    runDialogueEvent: 0
    dialogueEventId: 
  - choiceText: 'Fishing is silly '
    playerResponseText: 'Sorry Fisherfrog but fishing just isn''t my thing. However,
      I do respect that everyone has different interests and that any frog''s hobbies
      are no more valuable than anothers. Good day to you sir.   '
    nextNode: {fileID: 0}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 1
    finalChoice: 1
    runDialogueEvent: 0
