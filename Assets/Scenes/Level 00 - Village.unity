  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue_Node
  speakerName: 
  dialogueText: 'Froggle!  '
  choices:
  - choiceText: Darling Moonlily
    playerResponseText: '*yawns* Moonlily my love... What''s going on? Why are you
      so excited? '
    nextNode: {fileID: 1863162167}
    active: 1
    deactivateAfterChosen: 0
    finalChoice: 0
  - choiceText: Who are you?
    playerResponseText: 'Foul beast. Who are you and why are you in my room! '
    nextNode: {fileID: 1678142402}
    active: 1
    deactivateAfterChosen: 1
    finalChoice: 0
  - choiceText: Go Away
    playerResponseText: 'Moonlily I think we need to talk... '
    nextNode: {fileID: 63368922}
    active: 1
    deactivateAfterChosen: 1
    finalChoice: 0
