  m_Script: {fileID: 11500000, guid: 4eed38e452d87c7428f4c86506a4d752, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue_Node
  speakerName: 
  dialogueText: 'Sure. The apple hunt started many years ago, right after the civil
    war between the Swamp frogs and the Bull frogs. Elderfrog Bambla declared the
    hunt as a celebration of peace... although it was originally only supposed to
    take place once a year. These days the village frogs are too impatient to wait
    that long! '
  choices:
  - choiceText: 'I see. '
    playerResponseText: 'That''s really interesting. I have to go now. '
    nextNode: {fileID: 0}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
    objectsToActivate: []
    objectsToDeactivate: []
  - choiceText: 
    playerResponseText: 
    nextNode: {fileID: 0}
    active: 0
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
