--- !u!114 &1678142402
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1678142400}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4eed38e452d87c7428f4c86506a4d752, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue_Node
  speakerName: 
  dialogueText: 'Hah! Froggle you''re so silly sometimes! It''s me Moonlily your
    girlfrog of course. Now come on and get up!  '
  choices:
  - choiceText: Fine
    playerResponseText: Oof. Fineeee. But why are you so excited?
    nextNode: {fileID: 1863162167}
    active: 1
    deactivateAfterChosen: 0
    finalChoice: 0
  - choiceText: I don't want to
    playerResponseText: I'd rather not. And why are you so full of energy?
    nextNode: {fileID: 1863162167}
    active: 1
    deactivateAfterChosen: 0
    finalChoice: 0
