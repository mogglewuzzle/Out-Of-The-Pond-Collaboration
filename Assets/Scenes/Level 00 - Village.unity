  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue_Node
  speakerName: 
  dialogueText: 'Because it''s the weekly apple hunt! '
  choices:
  - choiceText: 'The apple hunt? '
    playerResponseText: 'The apple hunt? What is that? '
    nextNode: {fileID: 1710426774}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
    objectsToActivate: []
    objectsToDeactivate: []
  - choiceText: 'I don''t care.  '
    playerResponseText: 'I''m not interested in some stupid apple scavenger hunt.
      I''m a grown frogman not a child.  '
    nextNode: {fileID: 1710426774}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
    objectsToActivate: []
    objectsToDeactivate: []
