  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue_Node
  dialogueText: 'Erm... just the biggest day of the week of course. It''s when the
    villagers all scavenge the pond for fresh apples. Too bad you''re late though! '
  choices:
  - choiceText: Can I join?
    playerResponseText: 'Is it too late for me to join the hunt?  '
    nextNode: {fileID: 1870164293}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
    runDialogueEvent: 0
    dialogueEventId: 
  - choiceText: Demand to join
    playerResponseText: 'Look, I don''t have time for this bull-ruckus. Just tell
      me where the apples are now.  '
    nextNode: {fileID: 1517247649}
    active: 1
    deactivateAfterChosen: 1
    goodbyeChoice: 0
    finalChoice: 0
    runDialogueEvent: 0
    dialogueEventId: 
  - choiceText: Exorcise Applefrog
    playerResponseText: 'Erm.... I ahh. By the power of Elderfrog.... I hereby excorcise
      your dem- '
    nextNode: {fileID: 524623563}
    active: 1
    deactivateAfterChosen: 1
    goodbyeChoice: 0
    finalChoice: 0
