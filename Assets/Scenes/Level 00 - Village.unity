  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue_Node
  dialogueText: Hey Froggle! Where have you been all morning? You're late for the
    apple hunt!
  choices:
  - choiceText: Apple Hunt?
    playerResponseText: 'I beg your pardon? What is an apple hunt? '
    nextNode: {fileID: 1704386096}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
    runDialogueEvent: 0
    dialogueEventId: 
  - choiceText: I've been busy
    playerResponseText: 'I''ve been super busy watching the latest Frog Tok video:
      Good frogs gone wild'
    nextNode: {fileID: 285915417}
    active: 1
    deactivateAfterChosen: 1
    goodbyeChoice: 0
    finalChoice: 0
    runDialogueEvent: 0
    dialogueEventId: 
  - choiceText: I slept in
    playerResponseText: 'I totally slept in. And Moonlily was a bit upset with me
      I think. '
    nextNode: {fileID: 832671770}
