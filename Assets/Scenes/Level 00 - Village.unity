  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue_Node
  dialogueText: 'You almost drowned and now you''re in the hospital! Don''t you know
    that frogs in this village can''t swim in deep water?  '
  choices:
  - choiceText: Why
    playerResponseText: 'We can''t? But... we''re frogs!  '
    nextNode: {fileID: 262885121}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
    runDialogueEvent: 0
    dialogueEventId: 
  - choiceText: I CAN swim
    playerResponseText: '*angry* Nonsense! I am strong and I CAN swim. Let me out
      of here and I''ll show you! '
    nextNode: {fileID: 272146800}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
    runDialogueEvent: 0
