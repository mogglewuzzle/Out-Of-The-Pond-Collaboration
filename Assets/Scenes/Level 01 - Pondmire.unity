  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue_Node
  speakerName: 
  dialogueText: 'Hmm. The apple hunt is normally your favourite day of the week.
    The whole village gets together for it. Froggle... is everything okay?  '
