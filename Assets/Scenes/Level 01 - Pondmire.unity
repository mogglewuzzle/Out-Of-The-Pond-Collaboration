--- !u!114 &5451156
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5451154}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4eed38e452d87c7428f4c86506a4d752, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue_Node
  speakerName: 
  dialogueText: 'Me too! The whole village comes alive.  '
  choices:
  - choiceText: Apple Hunt Record
    playerResponseText: 'Who has the record for most apples collected in one bout? '
    nextNode: {fileID: 558081800}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
  - choiceText: History of Apple Hunt
    playerResponseText: Do you know anything about the history of the apple hunt?
    nextNode: {fileID: 404847057}
    active: 1
    deactivateAfterChosen: 1
    goodbyeChoice: 0
    finalChoice: 0
  - choiceText: Goodbye
    playerResponseText: 'I feel alive when I''m with you. Bye! '
    nextNode: {fileID: 0}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 1
    finalChoice: 0
