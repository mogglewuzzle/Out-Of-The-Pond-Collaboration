  m_Script: {fileID: 11500000, guid: 4eed38e452d87c7428f4c86506a4d752, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue_Node
  speakerName: 
  dialogueText: 'Hey Froggle. Enjoying the apple hunt? '
  choices:
  - choiceText: Apple Hunt
    playerResponseText: 'You bet! It''s my favourite day of the week. '
    nextNode: {fileID: 5451156}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
  - choiceText: How's life?
    playerResponseText: Don't you get bored having to stand guard out here all day?
    nextNode: {fileID: 483394895}
    active: 1
    deactivateAfterChosen: 1
    goodbyeChoice: 0
    finalChoice: 0
  - choiceText: Leave Village
    playerResponseText: I'd like to leave the village and explore the world!
    nextNode: {fileID: 1807509078}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
