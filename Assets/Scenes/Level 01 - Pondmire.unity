--- !u!114 &63368922
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 63368920}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4eed38e452d87c7428f4c86506a4d752, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue_Node
  speakerName: 
  dialogueText: 'Oh okay sure! What''s on your mind my sweet darling Froggle? My
    most beautiful cuddliest wuzzlepuffin! '
  choices:
  - choiceText: Oh. Nothing...
    playerResponseText: Huh? Oh, no it's nothing. Sorry I was just a little sleepy.
      Why are you so excited?
    nextNode: {fileID: 1863162167}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
  - choiceText: I need space
    playerResponseText: 'I just... I need a moment to think. '
    nextNode: {fileID: 1397343219}
    active: 1
    deactivateAfterChosen: 0
    goodbyeChoice: 0
    finalChoice: 0
